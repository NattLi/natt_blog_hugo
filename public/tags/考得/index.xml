            <title>写于高考倒计时200天</title>
            <link>https://blognew.natt.cc/posts/2006-11-19-%E5%86%99%E4%BA%8E%E9%AB%98%E8%80%83%E5%80%92%E8%AE%A1%E6%97%B6200%E5%A4%A9/</link>
